# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Resend email API key (https://resend.com — free tier exists).
# Leave unset to disable email and just print the digest to stdout.
RESEND_API_KEY=re_...

# Where the digest is sent (only used when RESEND_API_KEY is set)
DIGEST_RECIPIENT_EMAIL=you@example.com

# Sender address. Default 'onboarding@resend.dev' works without domain verification
# (Resend dev-only sender). For production use, set this to a verified sender on
# your own domain.
DIGEST_FROM_EMAIL=onboarding@resend.dev

# Slack incoming webhook for monitoring alerts (used in Stage 5)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
